# ============================================================
# Threads SNS 運用管理システム - 環境変数設定
# このファイルを .env にコピーして実際の値を入力してください
# ============================================================

# --- Threads / Meta API ---
# Meta Developer Portal で取得: https://developers.facebook.com/
THREADS_APP_ID=your_app_id_here
THREADS_APP_SECRET=your_app_secret_here
THREADS_ACCESS_TOKEN=your_access_token_here
THREADS_USER_ID=your_user_id_here

# --- Google Sheets API ---
# Google Cloud Console で取得: https://console.cloud.google.com/
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./config/google_service_account.json

# --- Claude AI API (トピック生成・文案作成用) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- システム設定 ---
TIMEZONE=Asia/Tokyo
DEFAULT_LANGUAGE=ja
REPORT_SAVE_DIR=./reports
DATA_SAVE_DIR=./data/insights

# --- ダッシュボード設定 ---
DASHBOARD_PORT=3000
DASHBOARD_SECRET=change_this_to_random_string
SESSION_SECRET=change_this_to_random_string

# --- Slack 通知 (オプション) ---
# Slack の Incoming Webhook URL を設定すると、エラー・投稿成功・トークン期限警告を通知します
# 設定方法: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
